---
import { VisualEditing } from "@sanity/astro/visual-editing";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import { urlFor } from "../utils/image";
import type { Settings, SanityImage } from "../utils/sanity";

interface Props {
  settings?: Settings;
  pageSeo?: {
    title?: string;
    description?: string;
    ogImage?: SanityImage;
  };
}

const { settings, pageSeo } = Astro.props;

const title =
  pageSeo?.title ?? settings?.siteTitle ?? settings?.churchName ?? "CDMC";
const description = pageSeo?.description ?? settings?.siteDescription ?? "";
const ogImageSource = pageSeo?.ogImage ?? settings?.ogImage;
const ogImageUrl = ogImageSource
  ? urlFor(ogImageSource).width(1200).height(630).fit("crop").auto("format").quality(80).url()
  : undefined;
const canonicalURL = Astro.url;

const churchJsonLd = settings
  ? {
      "@context": "https://schema.org",
      "@type": "Church",
      name: settings.churchName,
      description: settings.siteDescription,
      url: Astro.site?.href,
      telephone: settings.phone,
      email: settings.email,
      address: settings.address
        ? { "@type": "PostalAddress", streetAddress: settings.address }
        : undefined,
      image: ogImageUrl,
    }
  : null;

const websiteJsonLd = settings
  ? {
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: settings.churchName,
      url: Astro.site?.href,
    }
  : null;

const visualEditingEnabled =
  import.meta.env.PUBLIC_SANITY_VISUAL_EDITING_ENABLED === "true";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Primary SEO -->
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    {ogImageUrl && <meta property="og:image:width" content="1200" />}
    {ogImageUrl && <meta property="og:image:height" content="630" />}
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta
      name="twitter:card"
      content={ogImageUrl ? "summary_large_image" : "summary"}
    />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    <!-- JSON-LD -->
    {
      churchJsonLd && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(churchJsonLd)}
        />
      )
    }
    {
      websiteJsonLd && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(websiteJsonLd)}
        />
      )
    }

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <VisualEditing enabled={visualEditingEnabled} />
    <Header />
    <slot />
    <Footer />
  </body>
</html>
