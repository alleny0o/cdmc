---
import type { Home } from "../utils/sanity";
import { urlFor } from "../utils/image";
import { PortableText } from "astro-portabletext";
import Container from "./Container.astro";

interface Props {
  home: Home;
}

const { home } = Astro.props;

const section = home?.whoWeAre;
const title = section?.title || "Who We Are";
const bgColor = section?.backgroundColor?.hex || "#ffffff";
const textColor = section?.textColor?.hex || "#111111";
const hasImage = !!section?.image;
---

<section id="who-we-are">
  <Container class="py-20 flex flex-col md:flex-row items-center gap-12 md:gap-16">

    <!-- Text -->
    <div class="flex-1">
      <p class="section-label text-xs uppercase tracking-[0.25em] mb-4">{title}</p>
      <div class="w-8 h-px mb-8 section-divider"></div>
      {section?.body ? (
        <div class="font-serif italic text-xl md:text-2xl leading-relaxed section-body">
          <PortableText value={section.body} />
        </div>
      ) : (
        <p class="font-serif italic text-xl md:text-2xl leading-relaxed section-body">
          Striving to lead the missional life as we continue to grow and mature in becoming the disciples of Christ.
        </p>
      )}
    </div>

    <!-- Image or empty space -->
    <div class="flex-1">
      {hasImage && section?.image ? (
        <img
          src={urlFor(section.image)
            .width(900)
            .quality(90)
            .format("webp")
            .url()}
          alt="Who We Are"
          class="w-full aspect-video object-cover"
          loading="lazy"
          decoding="async"
          width="900"
          height="506"
        />
      ) : (
        <div class="w-full aspect-video section-placeholder" />
      )}
    </div>

  </Container>
</section>

<style define:vars={{ bgColor, textColor }}>
  #who-we-are {
    background-color: var(--bgColor);
  }
  .section-label {
    color: var(--textColor);
    opacity: 0.4;
    display: block;
  }
  .section-divider {
    background-color: var(--textColor);
    opacity: 0.2;
  }
  .section-body {
    color: var(--textColor);
  }
  .section-placeholder {
    background-color: var(--textColor);
    opacity: 0.03;
  }
</style>