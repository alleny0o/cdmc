---
import type { About, TeamMember } from "../utils/sanity";
import { urlFor } from "../utils/image";
import Container from "./Container.astro";

interface Props {
  about: About;
  team: TeamMember[];
}

const { about, team } = Astro.props;
const section = about?.team;
const bgColor = section?.backgroundColor?.hex || "#ffffff";
const textColor = section?.textColor?.hex || "#111111";
const title = section?.title || "Our Team";
---

<section id="our-team" style={`background-color: ${bgColor}; color: ${textColor}`}>
  <Container class="py-20">
    <span class="text-xs uppercase tracking-[0.25em] opacity-40 block mb-4">{title}</span>
    <div class="w-8 h-px bg-current opacity-20 mb-10"></div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-8 gap-y-12">
      {team.map((member) => (
        <div>
          {member.image ? (
            <img
              src={urlFor(member.image).width(600).quality(90).format("webp").url()}
              alt={member.name}
              class="w-full aspect-3/4 object-cover mb-3"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <div class="w-full aspect-3/4 bg-current opacity-5 mb-3" />
          )}
          <p class="text-sm font-light mb-0.5">{member.name}</p>
          <p class="text-[10px] uppercase tracking-[0.15em] opacity-40 mb-2">{member.role}</p>
          {member.slug && (
            <a
              href={`/about/${member.slug}`}
              class="text-[11px] opacity-40 hover:opacity-80 transition-opacity"
            >
              Bio →
            </a>
          )}
        </div>
      ))}
    </div>
  </Container>
</section>