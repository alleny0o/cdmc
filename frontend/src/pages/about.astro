---
import { getAbout, getTeamMembers, getSettings } from "../utils/sanity";
import type { About, TeamMember, Settings } from "../utils/sanity";
import Layout from "../layouts/Layout.astro";
import AboutUs from "../components/AboutUs.astro";
import OurHistory from "../components/OurHistory.astro";
import OurTeam from "../components/OurTeam.astro";

const settings = (await getSettings()) as Settings;
const about = (await getAbout()) as About;
const team = (await getTeamMembers()) as TeamMember[];
---

<Layout
  settings={settings}
  pageSeo={{
    title: about?.seo?.metaTitle,
    description: about?.seo?.metaDescription,
    ogImage: about?.seo?.ogImage,
  }}
>
  <AboutUs about={about} />
  <OurHistory about={about} />
  <OurTeam about={about} team={team} />
</Layout>