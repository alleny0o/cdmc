---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import WhoWeAre from "../components/WhoWeAre.astro";
import ServiceTimes from "../components/ServiceTimes.astro";
import { getSettings, getHome } from "../utils/sanity";
import type { Settings, Home } from "../utils/sanity";
import FeatureGallery from "../components/FeatureGallery.astro";

const settings = await getSettings() as Settings;
const home = await getHome() as Home;
---

<Layout
  settings={settings}
  pageSeo={{
    title: home?.seo?.metaTitle,
    description: home?.seo?.metaDescription,
    ogImage: home?.seo?.ogImage,
  }}
>
  <Hero home={home} settings={settings} />
  <WhoWeAre home={home} />
  <FeatureGallery home={home} />
  <ServiceTimes home={home} />
</Layout>